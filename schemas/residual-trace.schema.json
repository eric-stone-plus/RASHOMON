{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eric-stone-plus/RASHOMON/schemas/residual-trace.schema.json",
  "title": "RASHOMON Residual Trace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "question",
    "instrument",
    "residuals",
    "action_boundary",
    "highball_decision"
  ],
  "properties": {
    "trace_version": {
      "type": "string"
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "instrument": {
      "type": "string",
      "enum": [
        "MAGI",
        "QUINTE",
        "direct-evidence",
        "human"
      ]
    },
    "residuals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/residual"
      }
    },
    "action_boundary": {
      "type": "string",
      "enum": [
        "none",
        "reversible",
        "protected_write",
        "irreversible"
      ]
    },
    "highball_decision": {
      "type": "string",
      "enum": [
        "not_applicable",
        "pass",
        "review",
        "block",
        "escalate"
      ]
    },
    "trial_manifest": {
      "$ref": "#/$defs/trialManifest"
    }
  },
  "$defs": {
    "trialManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_version",
        "base_model_relation",
        "perspective_count",
        "perspectives",
        "perturbation_axes",
        "independence_controls",
        "contamination_risks",
        "cost"
      ],
      "properties": {
        "manifest_version": {
          "type": "string"
        },
        "base_model_relation": {
          "type": "string",
          "enum": [
            "unknown",
            "same_model",
            "same_family",
            "heterogeneous_models",
            "mixed",
            "human",
            "direct_evidence"
          ]
        },
        "perspective_count": {
          "type": "integer",
          "minimum": 1
        },
        "perspectives": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/perspective"
          }
        },
        "perturbation_axes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "independence_controls": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contamination_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cost": {
          "$ref": "#/$defs/trialCost"
        }
      }
    },
    "perspective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "route",
        "artifact",
        "prompt_hash",
        "independent_first_pass"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": [
            "string",
            "null"
          ]
        },
        "artifact": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "independent_first_pass": {
          "type": "boolean"
        }
      }
    },
    "trialCost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_tokens",
        "wall_time_seconds",
        "tool_calls",
        "human_minutes"
      ],
      "properties": {
        "total_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "wall_time_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "tool_calls": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "human_minutes": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "residual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "type",
        "source",
        "finding",
        "affected_paths",
        "error_signature",
        "evidence",
        "disposition",
        "required_closure",
        "closure_state",
        "closure_evidence",
        "scope"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "CRITICAL",
            "P0"
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "contradiction",
            "omission",
            "evidence_gap",
            "confidence_mismatch",
            "drift",
            "execution_mismatch",
            "silent_collapse"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "finding": {
          "type": "string",
          "minLength": 1
        },
        "affected_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error_signature": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence": {
          "type": [
            "string",
            "null"
          ]
        },
        "disposition": {
          "type": "string",
          "enum": [
            "verified",
            "falsified",
            "unresolved",
            "escalated",
            "discarded"
          ]
        },
        "required_closure": {
          "type": "string",
          "enum": [
            "none",
            "edit",
            "test",
            "command",
            "block",
            "waiver",
            "human_review"
          ]
        },
        "closure_state": {
          "type": "string",
          "enum": [
            "open",
            "closed",
            "blocked",
            "waived",
            "not_applicable"
          ]
        },
        "closure_evidence": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "scope": {
          "type": "string"
        }
      }
    }
  }
}
